# ============================================================
# VAIDYAMITRA Backend — Environment Configuration Template
#
# Copy this file: cp .env.example .env
# Then fill in your AWS credentials below.
# ============================================================

# --- AWS Credentials (REQUIRED for production) ---
# Get these from: AWS Console → IAM → Users → Security Credentials
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
# Optional: Only needed if using temporary STS credentials
AWS_SESSION_TOKEN=

# --- DynamoDB ---
# Leave DYNAMODB_ENDPOINT_URL empty to use AWS DynamoDB (recommended)
# Set to http://localhost:8001 for DynamoDB Local during offline dev
DYNAMODB_ENDPOINT_URL=
DYNAMODB_TABLE_PREFIX=vaidyamitra_

# --- S3 ---
S3_BUCKET_NAME=vaidyamitra-data
# Leave S3_ENDPOINT_URL empty for AWS S3 (recommended)
S3_ENDPOINT_URL=

# --- Bedrock (AI Engine) ---
# Model must be enabled in your AWS account: AWS Console → Bedrock → Model Access
BEDROCK_MODEL_ID=meta.llama3-8b-instruct-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_REGION=ap-south-1

# --- API Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False
CORS_ORIGINS=http://localhost:3000,http://localhost

# --- Security ---
API_KEYS=change_this_to_a_secure_key
SECRET_KEY=change_this_to_a_secure_secret

# --- Privacy Layer ---
PRESIDIO_CONFIDENCE_THRESHOLD=0.5

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Logging ---
LOG_LEVEL=INFO

# --- AI Mode ---
# 'auto' = use Bedrock if credentials present, else mock (RECOMMENDED)
# 'bedrock' = force Bedrock (fails if no credentials)
# 'mock' = force mock responses (no AWS needed, for offline dev)
AI_MODE=auto

# --- AI Cache Configuration ---
CACHE_ENABLED=true
CACHE_TTL_MEDICINE_HOURS=168
CACHE_TTL_JANAUSHADHI_HOURS=168
CACHE_TTL_DISEASE_HOURS=24
CACHE_TTL_REPORT_HOURS=72
CACHE_TTL_QUERY_HOURS=12
CACHE_TTL_EMBEDDING_HOURS=720
CACHE_MAX_MEMORY_ITEMS=500
